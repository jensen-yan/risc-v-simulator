{
  "version": 1,
  "description": "memory-first baseline：首轮 canonical baseline，包含 memory_learning 基础学习集与固定代表性 LSU / STREAM 微基准",
  "benchmarks": [
    {
      "suite": "riscv-tests",
      "name": "dhrystone",
      "path": "riscv-tests/benchmarks/dhrystone.riscv"
    },
    {
      "suite": "riscv-tests",
      "name": "memcpy",
      "path": "riscv-tests/benchmarks/memcpy.riscv"
    },
    {
      "suite": "riscv-tests",
      "name": "mm",
      "path": "riscv-tests/benchmarks/mm.riscv"
    },
    {
      "suite": "riscv-tests",
      "name": "spmv",
      "path": "riscv-tests/benchmarks/spmv.riscv"
    },
    {
      "suite": "coremark",
      "name": "coremark",
      "path": "benchmarks/build/coremark/coremark.riscv",
      "optional": true
    },
    {
      "suite": "custom-lsu",
      "name": "lsu_store_forward",
      "path": "benchmarks/build/lsu/lsu_store_forward.riscv",
      "optional": true
    },
    {
      "suite": "custom-lsu",
      "name": "lsu_stride_walk",
      "path": "benchmarks/build/lsu/lsu_stride_walk.riscv",
      "optional": true
    },
    {
      "suite": "custom-lsu",
      "name": "lsu_mlp",
      "path": "benchmarks/build/lsu/lsu_mlp.riscv",
      "optional": true
    },
    {
      "suite": "custom-lsu",
      "name": "stream_copy",
      "path": "benchmarks/build/lsu/stream_copy.riscv",
      "optional": true
    },
    {
      "suite": "custom-lsu",
      "name": "stream_triad",
      "path": "benchmarks/build/lsu/stream_triad.riscv",
      "optional": true
    }
  ]
}
